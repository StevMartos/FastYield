# datatype:
# - name: PlanetName
#   datatype: string
#   description: Planet Name
#   meta: !!omap
#   - {_votable_string_dtype: char}
#   subtype: json
# - name: StarName
#   datatype: string
#   description: Host Name
#   meta: !!omap
#   - {_votable_string_dtype: char}
#   subtype: json
# - {name: Period, unit: d, datatype: float64}
# - {name: SMA, unit: AU, datatype: float64}
# - {name: Ecc, datatype: float64}
# - {name: Inc, unit: deg, datatype: float64}
# - {name: PlanetMass, unit: earthMass, datatype: float64}
# - {name: +DeltaPlanetMass, unit: earthMass, datatype: float64}
# - {name: -DeltaPlanetMass, unit: earthMass, datatype: float64}
# - name: PlanetMassRef
#   datatype: string
#   description: Planet Mass or Mass*sin(i) [Earth Mass] Reference
#   meta: !!omap
#   - {_votable_string_dtype: char}
#   subtype: json
# - {name: PlanetRadius, unit: earthRad, datatype: float64}
